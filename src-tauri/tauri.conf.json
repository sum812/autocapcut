{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AutoCapcut",
  "version": "1.0.0",
  "identifier": "com.autocapcut.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AutoCapcut",
        "width": 1150,
        "height": 760,
        "resizable": true,
        "minWidth": 1000,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Vietnamese", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false
    }
  }
}
